# Quest@Stellar Backend — Database Configuration
# Use DATABASE_URL for a single connection string, or set individual PG_* variables.

# Option A: Connection string (takes precedence)
# DATABASE_URL=postgresql://user:password@localhost:5432/quest_stellar

# Option B: Individual variables
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=quest_stellar
PG_USER=postgres
PG_PASSWORD=

# Connection pool size (optional, default 10)
# PG_POOL_MAX=10
